## ================================================================
## DEEP TEST — tests EVERYTHING in HEX
## ================================================================

$passed -> 0
$failed -> 0

>> bold "=========================================="
>> bold "  HEX DEEP TEST SUITE"
>> bold "=========================================="

## ── VARIABLES & TYPES ──
>> "\n--- VARIABLES & TYPES ---"

$a -> 42
? $a == 42 :: $passed += 1 :: else :: >> red "[FAIL] int assign" ;; $failed += 1 ;;

$b -> 3.14
? $b == 3.14 :: $passed += 1 :: else :: >> red "[FAIL] float" ;; $failed += 1 ;;

$c -> "hello"
? $c == "hello" :: $passed += 1 :: else :: >> red "[FAIL] string" ;; $failed += 1 ;;

$d -> true
? $d == true :: $passed += 1 :: else :: >> red "[FAIL] bool" ;; $failed += 1 ;;

## ── MATH ──
>> "\n--- MATH ---"

? (5 + 3) == 8 :: $passed += 1 :: else :: >> red "[FAIL] add" ;; $failed += 1 ;;
? (10 - 7) == 3 :: $passed += 1 :: else :: >> red "[FAIL] sub" ;; $failed += 1 ;;
? (4 * 6) == 24 :: $passed += 1 :: else :: >> red "[FAIL] mul" ;; $failed += 1 ;;
? (20 / 4) == 5 :: $passed += 1 :: else :: >> red "[FAIL] div" ;; $failed += 1 ;;
? (17 % 5) == 2 :: $passed += 1 :: else :: >> red "[FAIL] mod" ;; $failed += 1 ;;
? (2 ^ 10) == 1024 :: $passed += 1 :: else :: >> red "[FAIL] pow" ;; $failed += 1 ;;
? (2 + 3 * 4) == 14 :: $passed += 1 :: else :: >> red "[FAIL] order of ops" ;; $failed += 1 ;;
? ((2 + 3) * 4) == 20 :: $passed += 1 :: else :: >> red "[FAIL] parens" ;; $failed += 1 ;;

## ── COMPOUND ASSIGNMENT ──
>> "\n--- COMPOUND ASSIGNMENT ---"

$x -> 10
$x += 5
? $x == 15 :: $passed += 1 :: else :: >> red "[FAIL] +=" ;; $failed += 1 ;;
$x -= 3
? $x == 12 :: $passed += 1 :: else :: >> red "[FAIL] -=" ;; $failed += 1 ;;
$x *= 2
? $x == 24 :: $passed += 1 :: else :: >> red "[FAIL] *=" ;; $failed += 1 ;;
$x /= 6
? $x == 4 :: $passed += 1 :: else :: >> red "[FAIL] /=" ;; $failed += 1 ;;

## ── COMPARISONS & LOGIC ──
>> "\n--- COMPARISONS & LOGIC ---"

? (5 == 5) == true :: $passed += 1 :: else :: >> red "[FAIL] ==" ;; $failed += 1 ;;
? (5 != 3) == true :: $passed += 1 :: else :: >> red "[FAIL] !=" ;; $failed += 1 ;;
? (10 > 5) == true :: $passed += 1 :: else :: >> red "[FAIL] >" ;; $failed += 1 ;;
? (3 < 7) == true :: $passed += 1 :: else :: >> red "[FAIL] <" ;; $failed += 1 ;;
? (true && true) == true :: $passed += 1 :: else :: >> red "[FAIL] &&" ;; $failed += 1 ;;
? (true && false) == false :: $passed += 1 :: else :: >> red "[FAIL] && false" ;; $failed += 1 ;;
? (false || true) == true :: $passed += 1 :: else :: >> red "[FAIL] ||" ;; $failed += 1 ;;
? (!!true) == false :: $passed += 1 :: else :: >> red "[FAIL] !!" ;; $failed += 1 ;;

## ── TERNARY ──
>> "\n--- TERNARY ---"

$r -> (true ? "yes" : "no")
? $r == "yes" :: $passed += 1 :: else :: >> red "[FAIL] ternary true" ;; $failed += 1 ;;

$r -> (false ? "yes" : "no")
? $r == "no" :: $passed += 1 :: else :: >> red "[FAIL] ternary false" ;; $failed += 1 ;;

$r -> (5 > 3 ? "big" : "small")
? $r == "big" :: $passed += 1 :: else :: >> red "[FAIL] ternary expr" ;; $failed += 1 ;;

## ── STRING INTERPOLATION ──
>> "\n--- STRING INTERPOLATION ---"

$name -> "HEX"
$r -> "lang={$name}"
? $r == "lang=HEX" :: $passed += 1 :: else :: >> red "[FAIL] interpolation" ;; $failed += 1 ;;

## ── STRING OPS ──
>> "\n--- STRING OPS ---"

$s -> "  hello  "
&trim $s
? $s == "hello" :: $passed += 1 :: else :: >> red "[FAIL] trim" ;; $failed += 1 ;;

$s -> "hello"
&upper $s
? $s == "HELLO" :: $passed += 1 :: else :: >> red "[FAIL] upper" ;; $failed += 1 ;;

&lower $s
? $s == "hello" :: $passed += 1 :: else :: >> red "[FAIL] lower" ;; $failed += 1 ;;

$s -> "hello world"
&title $s
? $s == "Hello World" :: $passed += 1 :: else :: >> red "[FAIL] title" ;; $failed += 1 ;;

$s -> "hello"
&capitalize $s
? $s == "Hello" :: $passed += 1 :: else :: >> red "[FAIL] capitalize" ;; $failed += 1 ;;

$s -> "Hello"
&swapcase $s
? $s == "hELLO" :: $passed += 1 :: else :: >> red "[FAIL] swapcase" ;; $failed += 1 ;;

$s -> "ha"
&repeat $s 3
? $s == "hahaha" :: $passed += 1 :: else :: >> red "[FAIL] repeat" ;; $failed += 1 ;;

## ── STRING INDEXING ──
>> "\n--- STRING INDEXING ---"

$s -> "abcdef"
? $s[0] == "a" :: $passed += 1 :: else :: >> red "[FAIL] index 0" ;; $failed += 1 ;;
? $s[3] == "d" :: $passed += 1 :: else :: >> red "[FAIL] index 3" ;; $failed += 1 ;;
? $s[-1] == "f" :: $passed += 1 :: else :: >> red "[FAIL] index -1" ;; $failed += 1 ;;
? $s[1:4] == "bcd" :: $passed += 1 :: else :: >> red "[FAIL] slice" ;; $failed += 1 ;;

## ── STRING PADDING ──
>> "\n--- STRING PADDING ---"

? (#padl "42" 6 "0") == "000042" :: $passed += 1 :: else :: >> red "[FAIL] padl" ;; $failed += 1 ;;
? (#padr "hi" 6 ".") == "hi...." :: $passed += 1 :: else :: >> red "[FAIL] padr" ;; $failed += 1 ;;

## ── LISTS ──
>> "\n--- LISTS ---"

$list -> [10, 20, 30, 40, 50]
? $list[0] == 10 :: $passed += 1 :: else :: >> red "[FAIL] list[0]" ;; $failed += 1 ;;
? $list[-1] == 50 :: $passed += 1 :: else :: >> red "[FAIL] list[-1]" ;; $failed += 1 ;;

&push $list 60
? (#len $list) == 6 :: $passed += 1 :: else :: >> red "[FAIL] push" ;; $failed += 1 ;;

&pop $list
? (#len $list) == 5 :: $passed += 1 :: else :: >> red "[FAIL] pop" ;; $failed += 1 ;;

$nums -> [3, 1, 4, 1, 5]
&sort $nums
? $nums[0] == 1 :: $passed += 1 :: else :: >> red "[FAIL] sort" ;; $failed += 1 ;;

&reverse $nums
? $nums[0] == 5 :: $passed += 1 :: else :: >> red "[FAIL] reverse" ;; $failed += 1 ;;

$nested -> [[1, 2], [3, 4], [5]]
&flat $nested
? (#len $nested) == 5 :: $passed += 1 :: else :: >> red "[FAIL] flat" ;; $failed += 1 ;;

&fill $zeros 0 4
? (#len $zeros) == 4 :: $passed += 1 :: else :: >> red "[FAIL] fill" ;; $failed += 1 ;;

## ── MAPS ──
>> "\n--- MAPS ---"

$m -> {"a": 1, "b": 2, "c": 3}
? $m["b"] == 2 :: $passed += 1 :: else :: >> red "[FAIL] map access" ;; $failed += 1 ;;

$m["d"] -> 4
? $m["d"] == 4 :: $passed += 1 :: else :: >> red "[FAIL] map set" ;; $failed += 1 ;;

## ── IF / ELSE ──
>> "\n--- IF / ELSE ---"

$r -> ""
$x -> 15
? $x > 20 ::
    $r -> "big"
?? $x > 10 ::
    $r -> "medium"
:: else ::
    $r -> "small"
;;
? $r == "medium" :: $passed += 1 :: else :: >> red "[FAIL] if-elseif" ;; $failed += 1 ;;

$r -> ""
? true ::
    ? false ::
        $r -> "wrong"
    :: else ::
        $r -> "right"
    ;;
;;
? $r == "right" :: $passed += 1 :: else :: >> red "[FAIL] nested if" ;; $failed += 1 ;;

## ── LOOPS ──
>> "\n--- LOOPS ---"

$sum -> 0
for $i in 1..10 ::
    $sum += $i
;;
? $sum == 55 :: $passed += 1 :: else :: >> red "[FAIL] for range" ;; $failed += 1 ;;

$r -> ""
for $item in ["a", "b", "c"] ::
    $r += $item
;;
? $r == "abc" :: $passed += 1 :: else :: >> red "[FAIL] for list" ;; $failed += 1 ;;

$count -> 0
while $count < 5 ::
    $count += 1
;;
? $count == 5 :: $passed += 1 :: else :: >> red "[FAIL] while" ;; $failed += 1 ;;

$count -> 0
rep 7 ::
    $count += 1
;;
? $count == 7 :: $passed += 1 :: else :: >> red "[FAIL] repeat" ;; $failed += 1 ;;

$count -> 0
forever ::
    $count += 1
    ? $count >= 3 :: break ;;
;;
? $count == 3 :: $passed += 1 :: else :: >> red "[FAIL] forever" ;; $failed += 1 ;;

$n -> 5
$runs -> 0
do ::
    $runs += 1
    $n -= 1
;; while $n > 3
? $runs == 2 :: $passed += 1 :: else :: >> red "[FAIL] do-while" ;; $failed += 1 ;;

$sum -> 0
for $i in 1..100 ::
    ? $i > 5 :: break ;;
    $sum += $i
;;
? $sum == 15 :: $passed += 1 :: else :: >> red "[FAIL] break" ;; $failed += 1 ;;

$sum -> 0
for $i in 1..10 ::
    ? $i % 2 == 0 :: continue ;;
    $sum += $i
;;
? $sum == 25 :: $passed += 1 :: else :: >> red "[FAIL] continue" ;; $failed += 1 ;;

## ── FUNCTIONS ──
>> "\n--- FUNCTIONS ---"

add $a $b ::
    => $a + $b
;;
? (add 10 20) == 30 :: $passed += 1 :: else :: >> red "[FAIL] func" ;; $failed += 1 ;;

factorial $n ::
    ? $n <= 1 :: => 1 ;;
    => $n * (factorial ($n - 1))
;;
? (factorial 6) == 720 :: $passed += 1 :: else :: >> red "[FAIL] recursion" ;; $failed += 1 ;;

## ── MAP / FILTER / REDUCE ──
>> "\n--- MAP / FILTER / REDUCE ---"

times3 $x ::
    => $x * 3
;;
$data -> [1, 2, 3, 4]
&map $data times3
? $data[0] == 3 :: $passed += 1 :: else :: >> red "[FAIL] map" ;; $failed += 1 ;;
? $data[3] == 12 :: $passed += 1 :: else :: >> red "[FAIL] map last" ;; $failed += 1 ;;

gt5 $x ::
    => $x > 5
;;
&filter $data gt5
? (#len $data) == 3 :: $passed += 1 :: else :: >> red "[FAIL] filter" ;; $failed += 1 ;;

sum2 $a $b ::
    => $a + $b
;;
&reduce $data sum2
? $data == 27 :: $passed += 1 :: else :: >> red "[FAIL] reduce" ;; $failed += 1 ;;

## ── MATCH / SWITCH ──
>> "\n--- MATCH / SWITCH ---"

$r -> ""
$cmd -> "greet"
match $cmd ::
    case "quit" ::
        $r -> "quitting"
    ;;
    case "greet" ::
        $r -> "hello!"
    ;;
    default ::
        $r -> "unknown"
    ;;
;;
? $r == "hello!" :: $passed += 1 :: else :: >> red "[FAIL] match" ;; $failed += 1 ;;

## ── CONSTANTS ──
>> "\n--- CONSTANTS ---"

lock $MAX -> 100
? $MAX == 100 :: $passed += 1 :: else :: >> red "[FAIL] lock" ;; $failed += 1 ;;

$lock_ok -> false
#try ::
    $MAX -> 999
#catch ::
    $lock_ok -> true
;;
? $lock_ok == true :: $passed += 1 :: else :: >> red "[FAIL] lock protect" ;; $failed += 1 ;;

## ── DESTRUCTURING ──
>> "\n--- DESTRUCTURING ---"

[$a, $b, $c] -> [100, 200, 300]
? $a == 100 :: $passed += 1 :: else :: >> red "[FAIL] destruct a" ;; $failed += 1 ;;
? $b == 200 :: $passed += 1 :: else :: >> red "[FAIL] destruct b" ;; $failed += 1 ;;
? $c == 300 :: $passed += 1 :: else :: >> red "[FAIL] destruct c" ;; $failed += 1 ;;

## ── CLASSES ──
>> "\n--- CLASSES ---"

class Counter ::
    init $start ::
        $this["val"] -> $start
    ;;
    inc ::
        $this["val"] -> $this["val"] + 1
    ;;
;;

$c -> new Counter 0
$c.inc
$c.inc
$c.inc
? $c["val"] == 3 :: $passed += 1 :: else :: >> red "[FAIL] class" ;; $failed += 1 ;;

## ── INHERITANCE ──
>> "\n--- INHERITANCE ---"

class Shape ::
    init $type ::
        $this["type"] -> $type
    ;;
;;

class Circle extends Shape ::
    init $r ::
        $this["type"] -> "circle"
        $this["r"] -> $r
    ;;
;;

$c -> new Circle 5
? $c["type"] == "circle" :: $passed += 1 :: else :: >> red "[FAIL] inherit" ;; $failed += 1 ;;
? $c["r"] == 5 :: $passed += 1 :: else :: >> red "[FAIL] inherit prop" ;; $failed += 1 ;;

## ── ENUMS ──
>> "\n--- ENUMS ---"

enum Dir ::
    north
    south
    east
    west
;;

? $Dir["north"] == 0 :: $passed += 1 :: else :: >> red "[FAIL] enum 0" ;; $failed += 1 ;;
? $Dir["west"] == 3 :: $passed += 1 :: else :: >> red "[FAIL] enum 3" ;; $failed += 1 ;;


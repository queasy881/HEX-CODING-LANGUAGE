>> "\n--- FILES ---"

~write "__deep_test_tmp.txt" "hello"
? (~exists "__deep_test_tmp.txt") == true :: $passed += 1 :: else :: >> red "[FAIL] file write" ;; $failed += 1 ;;

$content -> ~read "__deep_test_tmp.txt"
? $content == "hello" :: $passed += 1 :: else :: >> red "[FAIL] file read" ;; $failed += 1 ;;

~del "__deep_test_tmp.txt"
? (~exists "__deep_test_tmp.txt") == false :: $passed += 1 :: else :: >> red "[FAIL] file del" ;; $failed += 1 ;;


## ── ERROR HANDLING ──
>> "\n--- ERROR HANDLING ---"

$caught -> false
#try ::
    $x -> 10 / 0
#catch ::
    $caught -> true
;;
? $caught == true :: $passed += 1 :: else :: >> red "[FAIL] try/catch" ;; $failed += 1 ;;

$typed -> false
#try ::
    $x -> 10 / 0
#catch ZeroDivisionError ::
    $typed -> true
;;
? $typed == true :: $passed += 1 :: else :: >> red "[FAIL] typed catch" ;; $failed += 1 ;;

$fin -> false
#try ::
    $x -> 10 / 0
#catch ::
    $caught -> true
#finally ::
    $fin -> true
;;
? $fin == true :: $passed += 1 :: else :: >> red "[FAIL] finally" ;; $failed += 1 ;;


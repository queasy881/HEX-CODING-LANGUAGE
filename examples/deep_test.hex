## ================================================================
## DEEP TEST — tests EVERYTHING in HEX
## ================================================================

$passed -> 0
$failed -> 0

## Using >> directly instead of a function to avoid scope issues

>> bold "=========================================="
>> bold "  HEX DEEP TEST SUITE"
>> bold "=========================================="

## ────────────────────────────────────────
>> "\n--- VARIABLES & TYPES ---"
## ────────────────────────────────────────

$a -> 42
? $a == 42 :: $passed += 1 ;; ? $a != 42 :: >> red "[FAIL] int assign" ;; $failed += 1 ;;

$b -> 3.14
? $b == 3.14 :: $passed += 1 ;; ? $b != 3.14 :: >> red "[FAIL] float" ;; $failed += 1 ;;

$c -> "hello"
? $c == "hello" :: $passed += 1 ;; ? $c != "hello" :: >> red "[FAIL] string" ;; $failed += 1 ;;

$d -> true
? $d == true :: $passed += 1 ;; ? $d != true :: >> red "[FAIL] bool" ;; $failed += 1 ;;

$e -> null
? $e == null :: $passed += 1 ;; ? $e != null :: >> red "[FAIL] null" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MATH ---"
## ────────────────────────────────────────

? (5 + 3) == 8 :: $passed += 1 ;; ? (5 + 3) != 8 :: >> red "[FAIL] add" ;; $failed += 1 ;;
? (10 - 7) == 3 :: $passed += 1 ;; ? (10 - 7) != 3 :: >> red "[FAIL] sub" ;; $failed += 1 ;;
? (4 * 6) == 24 :: $passed += 1 ;; ? (4 * 6) != 24 :: >> red "[FAIL] mul" ;; $failed += 1 ;;
? (20 / 4) == 5 :: $passed += 1 ;; ? (20 / 4) != 5 :: >> red "[FAIL] div" ;; $failed += 1 ;;
? (17 % 5) == 2 :: $passed += 1 ;; ? (17 % 5) != 2 :: >> red "[FAIL] mod" ;; $failed += 1 ;;
? (2 ^ 10) == 1024 :: $passed += 1 ;; ? (2 ^ 10) != 1024 :: >> red "[FAIL] pow" ;; $failed += 1 ;;
? (2 + 3 * 4) == 14 :: $passed += 1 ;; ? (2 + 3 * 4) != 14 :: >> red "[FAIL] order" ;; $failed += 1 ;;
? ((2 + 3) * 4) == 20 :: $passed += 1 ;; ? ((2 + 3) * 4) != 20 :: >> red "[FAIL] parens" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- COMPOUND ASSIGNMENT ---"
## ────────────────────────────────────────

$x -> 10
$x += 5
? $x == 15 :: $passed += 1 ;; ? $x != 15 :: >> red "[FAIL] +=" ;; $failed += 1 ;;
$x -= 3
? $x == 12 :: $passed += 1 ;; ? $x != 12 :: >> red "[FAIL] -=" ;; $failed += 1 ;;
$x *= 2
? $x == 24 :: $passed += 1 ;; ? $x != 24 :: >> red "[FAIL] *=" ;; $failed += 1 ;;
$x /= 6
? $x == 4 :: $passed += 1 ;; ? $x != 4 :: >> red "[FAIL] /=" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- COMPARISONS & LOGIC ---"
## ────────────────────────────────────────

? (5 == 5) == true :: $passed += 1 ;; ? (5 == 5) != true :: >> red "[FAIL] ==" ;; $failed += 1 ;;
? (5 != 3) == true :: $passed += 1 ;; ? (5 != 3) != true :: >> red "[FAIL] !=" ;; $failed += 1 ;;
? (10 > 5) == true :: $passed += 1 ;; ? (10 > 5) != true :: >> red "[FAIL] >" ;; $failed += 1 ;;
? (3 < 7) == true :: $passed += 1 ;; ? (3 < 7) != true :: >> red "[FAIL] <" ;; $failed += 1 ;;
? (true && true) == true :: $passed += 1 ;; ? (true && true) != true :: >> red "[FAIL] &&" ;; $failed += 1 ;;
? (true && false) == false :: $passed += 1 ;; ? (true && false) != false :: >> red "[FAIL] && false" ;; $failed += 1 ;;
? (false || true) == true :: $passed += 1 ;; ? (false || true) != true :: >> red "[FAIL] ||" ;; $failed += 1 ;;
? (!!true) == false :: $passed += 1 ;; ? (!!true) != false :: >> red "[FAIL] !!" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- TERNARY ---"
## ────────────────────────────────────────

$r -> (true ? "yes" : "no")
? $r == "yes" :: $passed += 1 ;; ? $r != "yes" :: >> red "[FAIL] ternary true" ;; $failed += 1 ;;

$r -> (false ? "yes" : "no")
? $r == "no" :: $passed += 1 ;; ? $r != "no" :: >> red "[FAIL] ternary false" ;; $failed += 1 ;;

$r -> (5 > 3 ? "big" : "small")
? $r == "big" :: $passed += 1 ;; ? $r != "big" :: >> red "[FAIL] ternary expr" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- STRING INTERPOLATION ---"
## ────────────────────────────────────────

$name -> "HEX"
$r -> "lang={$name}"
? $r == "lang=HEX" :: $passed += 1 ;; ? $r != "lang=HEX" :: >> red "[FAIL] interpolation" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- STRING OPS ---"
## ────────────────────────────────────────

$s -> "  hello  "
&trim $s
? $s == "hello" :: $passed += 1 ;; ? $s != "hello" :: >> red "[FAIL] trim" ;; $failed += 1 ;;

$s -> "hello"
&upper $s
? $s == "HELLO" :: $passed += 1 ;; ? $s != "HELLO" :: >> red "[FAIL] upper" ;; $failed += 1 ;;

&lower $s
? $s == "hello" :: $passed += 1 ;; ? $s != "hello" :: >> red "[FAIL] lower" ;; $failed += 1 ;;

$s -> "hello world"
&title $s
? $s == "Hello World" :: $passed += 1 ;; ? $s != "Hello World" :: >> red "[FAIL] title" ;; $failed += 1 ;;

$s -> "hello"
&capitalize $s
? $s == "Hello" :: $passed += 1 ;; ? $s != "Hello" :: >> red "[FAIL] capitalize" ;; $failed += 1 ;;

$s -> "Hello"
&swapcase $s
? $s == "hELLO" :: $passed += 1 ;; ? $s != "hELLO" :: >> red "[FAIL] swapcase" ;; $failed += 1 ;;

$s -> "ha"
&repeat $s 3
? $s == "hahaha" :: $passed += 1 ;; ? $s != "hahaha" :: >> red "[FAIL] repeat" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- STRING INDEXING ---"
## ────────────────────────────────────────

$s -> "abcdef"
? $s[0] == "a" :: $passed += 1 ;; ? $s[0] != "a" :: >> red "[FAIL] index 0" ;; $failed += 1 ;;
? $s[3] == "d" :: $passed += 1 ;; ? $s[3] != "d" :: >> red "[FAIL] index 3" ;; $failed += 1 ;;
? $s[-1] == "f" :: $passed += 1 ;; ? $s[-1] != "f" :: >> red "[FAIL] index -1" ;; $failed += 1 ;;
? $s[1:4] == "bcd" :: $passed += 1 ;; ? $s[1:4] != "bcd" :: >> red "[FAIL] slice" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- STRING PADDING ---"
## ────────────────────────────────────────

? (#padl "42" 6 "0") == "000042" :: $passed += 1 ;; ? (#padl "42" 6 "0") != "000042" :: >> red "[FAIL] padl" ;; $failed += 1 ;;
? (#padr "hi" 6 ".") == "hi...." :: $passed += 1 ;; ? (#padr "hi" 6 ".") != "hi...." :: >> red "[FAIL] padr" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- LISTS ---"
## ────────────────────────────────────────

$list -> [10, 20, 30, 40, 50]
? $list[0] == 10 :: $passed += 1 ;; ? $list[0] != 10 :: >> red "[FAIL] list[0]" ;; $failed += 1 ;;
? $list[-1] == 50 :: $passed += 1 ;; ? $list[-1] != 50 :: >> red "[FAIL] list[-1]" ;; $failed += 1 ;;

&push $list 60
? (#len $list) == 6 :: $passed += 1 ;; ? (#len $list) != 6 :: >> red "[FAIL] push" ;; $failed += 1 ;;

&pop $list
? (#len $list) == 5 :: $passed += 1 ;; ? (#len $list) != 5 :: >> red "[FAIL] pop" ;; $failed += 1 ;;

$nums -> [3, 1, 4, 1, 5]
&sort $nums
? $nums[0] == 1 :: $passed += 1 ;; ? $nums[0] != 1 :: >> red "[FAIL] sort" ;; $failed += 1 ;;

&reverse $nums
? $nums[0] == 5 :: $passed += 1 ;; ? $nums[0] != 5 :: >> red "[FAIL] reverse" ;; $failed += 1 ;;

$nested -> [[1, 2], [3, 4], [5]]
&flat $nested
? $nested == [1, 2, 3, 4, 5] :: $passed += 1 ;; ? $nested != [1, 2, 3, 4, 5] :: >> red "[FAIL] flat" ;; $failed += 1 ;;

&fill $zeros 0 4
? $zeros == [0, 0, 0, 0] :: $passed += 1 ;; ? $zeros != [0, 0, 0, 0] :: >> red "[FAIL] fill" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MAPS ---"
## ────────────────────────────────────────

$m -> {"a": 1, "b": 2, "c": 3}
? $m["b"] == 2 :: $passed += 1 ;; ? $m["b"] != 2 :: >> red "[FAIL] map access" ;; $failed += 1 ;;

$m["d"] -> 4
? $m["d"] == 4 :: $passed += 1 ;; ? $m["d"] != 4 :: >> red "[FAIL] map set" ;; $failed += 1 ;;

&del $m "c"
? (#len $m) == 3 :: $passed += 1 ;; ? (#len $m) != 3 :: >> red "[FAIL] map del" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- IF / ELSE ---"
## ────────────────────────────────────────

$r -> ""
$x -> 15
? $x > 20 ::
    $r -> "big"
?? $x > 10 ::
    $r -> "medium"
:: else ::
    $r -> "small"
;;
? $r == "medium" :: $passed += 1 ;; ? $r != "medium" :: >> red "[FAIL] if-elseif" ;; $failed += 1 ;;

## Nested if
$r -> ""
? true ::
    ? false ::
        $r -> "wrong"
    :: else ::
        $r -> "right"
    ;;
;;
? $r == "right" :: $passed += 1 ;; ? $r != "right" :: >> red "[FAIL] nested if" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- LOOPS ---"
## ────────────────────────────────────────

## For range
$sum -> 0
for $i in 1..10 ::
    $sum += $i
;;
? $sum == 55 :: $passed += 1 ;; ? $sum != 55 :: >> red "[FAIL] for range" ;; $failed += 1 ;;

## For list
$r -> ""
for $item in ["a", "b", "c"] ::
    $r += $item
;;
? $r == "abc" :: $passed += 1 ;; ? $r != "abc" :: >> red "[FAIL] for list" ;; $failed += 1 ;;

## While
$count -> 0
while $count < 5 ::
    $count += 1
;;
? $count == 5 :: $passed += 1 ;; ? $count != 5 :: >> red "[FAIL] while" ;; $failed += 1 ;;

## Repeat
$count -> 0
rep 7 ::
    $count += 1
;;
? $count == 7 :: $passed += 1 ;; ? $count != 7 :: >> red "[FAIL] repeat loop" ;; $failed += 1 ;;

## Forever + break
$count -> 0
forever ::
    $count += 1
    ? $count >= 3 :: break ;;
;;
? $count == 3 :: $passed += 1 ;; ? $count != 3 :: >> red "[FAIL] forever" ;; $failed += 1 ;;

## Do-while
$n -> 5
$runs -> 0
do ::
    $runs += 1
    $n -= 1
;; while $n > 3
? $runs == 2 :: $passed += 1 ;; ? $runs != 2 :: >> red "[FAIL] do-while" ;; $failed += 1 ;;

## Break
$sum -> 0
for $i in 1..100 ::
    ? $i > 5 :: break ;;
    $sum += $i
;;
? $sum == 15 :: $passed += 1 ;; ? $sum != 15 :: >> red "[FAIL] break" ;; $failed += 1 ;;

## Continue
$sum -> 0
for $i in 1..10 ::
    ? $i % 2 == 0 :: continue ;;
    $sum += $i
;;
? $sum == 25 :: $passed += 1 ;; ? $sum != 25 :: >> red "[FAIL] continue" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- FUNCTIONS ---"
## ────────────────────────────────────────

add $a $b ::
    => $a + $b
;;
? (add 10 20) == 30 :: $passed += 1 ;; ? (add 10 20) != 30 :: >> red "[FAIL] func" ;; $failed += 1 ;;

factorial $n ::
    ? $n <= 1 :: => 1 ;;
    => $n * (factorial ($n - 1))
;;
? (factorial 6) == 720 :: $passed += 1 ;; ? (factorial 6) != 720 :: >> red "[FAIL] recursion" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MAP / FILTER / REDUCE ---"
## ────────────────────────────────────────

times3 $x ::
    => $x * 3
;;
$data -> [1, 2, 3, 4]
&map $data times3
? $data == [3, 6, 9, 12] :: $passed += 1 ;; ? $data != [3, 6, 9, 12] :: >> red "[FAIL] map" ;; $failed += 1 ;;

gt5 $x ::
    => $x > 5
;;
&filter $data gt5
? $data == [6, 9, 12] :: $passed += 1 ;; ? $data != [6, 9, 12] :: >> red "[FAIL] filter" ;; $failed += 1 ;;

sum2 $a $b ::
    => $a + $b
;;
&reduce $data sum2
? $data == 27 :: $passed += 1 ;; ? $data != 27 :: >> red "[FAIL] reduce" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MATCH / SWITCH ---"
## ────────────────────────────────────────

$r -> ""
$cmd -> "greet"
match $cmd ::
    case "quit" ::
        $r -> "quitting"
    ;;
    case "greet" ::
        $r -> "hello!"
    ;;
    default ::
        $r -> "unknown"
    ;;
;;
? $r == "hello!" :: $passed += 1 ;; ? $r != "hello!" :: >> red "[FAIL] match" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- CONSTANTS ---"
## ────────────────────────────────────────

lock $MAX -> 100
? $MAX == 100 :: $passed += 1 ;; ? $MAX != 100 :: >> red "[FAIL] lock" ;; $failed += 1 ;;

$lock_ok -> false
#try ::
    $MAX -> 999
#catch ::
    $lock_ok -> true
;;
? $lock_ok == true :: $passed += 1 ;; ? $lock_ok != true :: >> red "[FAIL] lock protect" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- DESTRUCTURING ---"
## ────────────────────────────────────────

[$a, $b, $c] -> [100, 200, 300]
? $a == 100 :: $passed += 1 ;; ? $a != 100 :: >> red "[FAIL] destruct a" ;; $failed += 1 ;;
? $b == 200 :: $passed += 1 ;; ? $b != 200 :: >> red "[FAIL] destruct b" ;; $failed += 1 ;;
? $c == 300 :: $passed += 1 ;; ? $c != 300 :: >> red "[FAIL] destruct c" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- CLASSES ---"
## ────────────────────────────────────────

class Counter ::
    init $start ::
        $this["val"] -> $start
    ;;
    inc ::
        $this["val"] -> $this["val"] + 1
    ;;
;;

$c -> new Counter 0
$c.inc
$c.inc
$c.inc
? $c["val"] == 3 :: $passed += 1 ;; ? $c["val"] != 3 :: >> red "[FAIL] class" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- INHERITANCE ---"
## ────────────────────────────────────────

class Shape ::
    init $type ::
        $this["type"] -> $type
    ;;
;;

class Circle extends Shape ::
    init $r ::
        $this["type"] -> "circle"
        $this["r"] -> $r
    ;;
;;

$c -> new Circle 5
? $c["type"] == "circle" :: $passed += 1 ;; ? $c["type"] != "circle" :: >> red "[FAIL] inherit" ;; $failed += 1 ;;
? $c["r"] == 5 :: $passed += 1 ;; ? $c["r"] != 5 :: >> red "[FAIL] inherit prop" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- ENUMS ---"
## ────────────────────────────────────────

enum Dir ::
    north
    south
    east
    west
;;

? $Dir["north"] == 0 :: $passed += 1 ;; ? $Dir["north"] != 0 :: >> red "[FAIL] enum 0" ;; $failed += 1 ;;
? $Dir["west"] == 3 :: $passed += 1 ;; ? $Dir["west"] != 3 :: >> red "[FAIL] enum 3" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- TYPE CHECKS ---"
## ────────────────────────────────────────

? (#isnum 42) == true :: $passed += 1 ;; ? (#isnum 42) != true :: >> red "[FAIL] isnum" ;; $failed += 1 ;;
? (#isstr "hi") == true :: $passed += 1 ;; ? (#isstr "hi") != true :: >> red "[FAIL] isstr" ;; $failed += 1 ;;
? (#islist [1]) == true :: $passed += 1 ;; ? (#islist [1]) != true :: >> red "[FAIL] islist" ;; $failed += 1 ;;
? (#isbool true) == true :: $passed += 1 ;; ? (#isbool true) != true :: >> red "[FAIL] isbool" ;; $failed += 1 ;;
? (#isnull null) == true :: $passed += 1 ;; ? (#isnull null) != true :: >> red "[FAIL] isnull" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MATH BUILTINS ---"
## ────────────────────────────────────────

? (#abs -42) == 42 :: $passed += 1 ;; ? (#abs -42) != 42 :: >> red "[FAIL] abs" ;; $failed += 1 ;;
? (#round 3.7) == 4 :: $passed += 1 ;; ? (#round 3.7) != 4 :: >> red "[FAIL] round" ;; $failed += 1 ;;
? (#floor 3.9) == 3 :: $passed += 1 ;; ? (#floor 3.9) != 3 :: >> red "[FAIL] floor" ;; $failed += 1 ;;
? (#ceil 3.1) == 4 :: $passed += 1 ;; ? (#ceil 3.1) != 4 :: >> red "[FAIL] ceil" ;; $failed += 1 ;;
? (#sqrt 144) == 12 :: $passed += 1 ;; ? (#sqrt 144) != 12 :: >> red "[FAIL] sqrt" ;; $failed += 1 ;;
? (#min 3 7) == 3 :: $passed += 1 ;; ? (#min 3 7) != 3 :: >> red "[FAIL] min" ;; $failed += 1 ;;
? (#max 3 7) == 7 :: $passed += 1 ;; ? (#max 3 7) != 7 :: >> red "[FAIL] max" ;; $failed += 1 ;;
? (#clamp 15 0 10) == 10 :: $passed += 1 ;; ? (#clamp 15 0 10) != 10 :: >> red "[FAIL] clamp" ;; $failed += 1 ;;
? (#sign -5) == -1 :: $passed += 1 ;; ? (#sign -5) != -1 :: >> red "[FAIL] sign" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- CASTING ---"
## ────────────────────────────────────────

? (#int "42") == 42 :: $passed += 1 ;; ? (#int "42") != 42 :: >> red "[FAIL] int" ;; $failed += 1 ;;
? (#str 42) == "42" :: $passed += 1 ;; ? (#str 42) != "42" :: >> red "[FAIL] str" ;; $failed += 1 ;;
? (#num "abc") == null :: $passed += 1 ;; ? (#num "abc") != null :: >> red "[FAIL] num safe" ;; $failed += 1 ;;
? (#bool 1) == true :: $passed += 1 ;; ? (#bool 1) != true :: >> red "[FAIL] bool" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- RANGE ---"
## ────────────────────────────────────────

? (#range 1 5) == [1, 2, 3, 4, 5] :: $passed += 1 ;; ? (#range 1 5) != [1, 2, 3, 4, 5] :: >> red "[FAIL] range" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- BASE64 ---"
## ────────────────────────────────────────

$enc -> #base64 "hello world"
? $enc == "aGVsbG8gd29ybGQ=" :: $passed += 1 ;; ? $enc != "aGVsbG8gd29ybGQ=" :: >> red "[FAIL] base64" ;; $failed += 1 ;;

$dec -> #decode64 $enc
? $dec == "hello world" :: $passed += 1 ;; ? $dec != "hello world" :: >> red "[FAIL] decode64" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- HEX CIPHER ---"
## ────────────────────────────────────────

$secret -> "top secret 123"
$enc -> #encrypt $secret "mykey"
$dec -> #decrypt $enc "mykey"
? $dec == $secret :: $passed += 1 ;; ? $dec != $secret :: >> red "[FAIL] encrypt/decrypt" ;; $failed += 1 ;;

## Random salt = different output
$e1 -> #encrypt "test" "k"
$e2 -> #encrypt "test" "k"
? $e1 != $e2 :: $passed += 1 ;; ? $e1 == $e2 :: >> red "[FAIL] random salt" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- JSON ---"
## ────────────────────────────────────────

$obj -> #json '{"name":"Niko","age":17,"scores":[90,85]}'
? $obj["name"] == "Niko" :: $passed += 1 ;; ? $obj["name"] != "Niko" :: >> red "[FAIL] json name" ;; $failed += 1 ;;
? $obj["age"] == 17 :: $passed += 1 ;; ? $obj["age"] != 17 :: >> red "[FAIL] json age" ;; $failed += 1 ;;
? $obj["scores"][0] == 90 :: $passed += 1 ;; ? $obj["scores"][0] != 90 :: >> red "[FAIL] json array" ;; $failed += 1 ;;

$back -> #jsonc $obj
? (#test $back "Niko") == true :: $passed += 1 ;; ? (#test $back "Niko") != true :: >> red "[FAIL] tojson" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- REGEX ---"
## ────────────────────────────────────────

$all -> #matchall "a1 b2 c3" "[a-z]\\d"
? (#len $all) == 3 :: $passed += 1 ;; ? (#len $all) != 3 :: >> red "[FAIL] matchall" ;; $failed += 1 ;;

$cleaned -> #replacex "a  b   c" "\\s+" " "
? $cleaned == "a b c" :: $passed += 1 ;; ? $cleaned != "a b c" :: >> red "[FAIL] replacex" ;; $failed += 1 ;;

? (#test "abc123" "^[a-z]+\\d+$") == true :: $passed += 1 ;; ? (#test "abc123" "^[a-z]+\\d+$") != true :: >> red "[FAIL] regex test" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- ERROR HANDLING ---"
## ────────────────────────────────────────

$caught -> false
#try ::
    $x -> 10 / 0
#catch ::
    $caught -> true
;;
? $caught == true :: $passed += 1 ;; ? $caught != true :: >> red "[FAIL] try/catch" ;; $failed += 1 ;;

## Typed catch
$typed -> false
#try ::
    $x -> 10 / 0
#catch ZeroDivisionError ::
    $typed -> true
;;
? $typed == true :: $passed += 1 ;; ? $typed != true :: >> red "[FAIL] typed catch" ;; $failed += 1 ;;

## Finally
$fin -> false
#try ::
    $x -> 10 / 0
#catch ::
    $caught -> true
#finally ::
    $fin -> true
;;
? $fin == true :: $passed += 1 ;; ? $fin != true :: >> red "[FAIL] finally" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- FILES ---"
## ────────────────────────────────────────

~write "__deep_test_tmp.txt" "hello"
? (~exists "__deep_test_tmp.txt") == true :: $passed += 1 ;; ? (~exists "__deep_test_tmp.txt") != true :: >> red "[FAIL] file write" ;; $failed += 1 ;;

$content -> ~read "__deep_test_tmp.txt"
? $content == "hello" :: $passed += 1 ;; ? $content != "hello" :: >> red "[FAIL] file read" ;; $failed += 1 ;;

~del "__deep_test_tmp.txt"
? (~exists "__deep_test_tmp.txt") == false :: $passed += 1 ;; ? (~exists "__deep_test_tmp.txt") != false :: >> red "[FAIL] file del" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- MULTI-LINE STRINGS ---"
## ────────────────────────────────────────

$ml -> """line1
line2"""
? (#test $ml "line1") == true :: $passed += 1 ;; ? (#test $ml "line1") != true :: >> red "[FAIL] multiline" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- DATE / TIME ---"
## ────────────────────────────────────────

$d -> #date
? (#test $d "^\\d{4}") == true :: $passed += 1 ;; ? (#test $d "^\\d{4}") != true :: >> red "[FAIL] date" ;; $failed += 1 ;;

$t -> #time
? (#isnum $t) == true :: $passed += 1 ;; ? (#isnum $t) != true :: >> red "[FAIL] time" ;; $failed += 1 ;;

## ────────────────────────────────────────
>> "\n--- COMPLEX SCENARIOS ---"
## ────────────────────────────────────────

## Nested loops
$sum -> 0
$matrix -> [[1, 2], [3, 4], [5, 6]]
for $row in $matrix ::
    for $val in $row ::
        $sum += $val
    ;;
;;
? $sum == 21 :: $passed += 1 ;; ? $sum != 21 :: >> red "[FAIL] nested loops" ;; $failed += 1 ;;

## Function + destructuring
get_pair ::
    => [42, 99]
;;
[$x, $y] -> get_pair
? $x == 42 :: $passed += 1 ;; ? $x != 42 :: >> red "[FAIL] func+destruct" ;; $failed += 1 ;;

## Chained string ops
$s -> "  Hello, World!  "
&trim $s
&lower $s
&replace $s "," ""
&replace $s "!" ""
? $s == "hello world" :: $passed += 1 ;; ? $s != "hello world" :: >> red "[FAIL] chained ops" ;; $failed += 1 ;;

## JSON + map combo
$config -> #json '{"debug": true, "port": 8080}'
? $config["port"] == 8080 :: $passed += 1 ;; ? $config["port"] != 8080 :: >> red "[FAIL] json config" ;; $failed += 1 ;;

## ════════════════════════════════════════
>> "\n=========================================="
>> bold "  RESULTS"
>> "=========================================="
$total -> $passed + $failed
>> green "  Passed: {$passed}"
? $failed > 0 ::
    >> red "  Failed: {$failed}"
:: else ::
    >> green "  Failed: 0"
;;
>> "  Total:  {$total}"
>> "=========================================="
? $failed == 0 ::
    >> green "  ALL TESTS PASSED"
:: else ::
    >> red "  SOME TESTS FAILED"
;;
>> "=========================================="

>> "\n--- DATE / TIME ---"

$d -> #date
? (#test $d "^\\d{4}") == true :: $passed += 1 :: else :: >> red "[FAIL] date" ;; $failed += 1 ;;

$t -> #time
? (#isnum $t) == true :: $passed += 1 :: else :: >> red "[FAIL] time" ;; $failed += 1 ;;

## ── COMPLEX SCENARIOS ──
>> "\n--- COMPLEX SCENARIOS ---"

$sum -> 0
$matrix -> [[1, 2], [3, 4], [5, 6]]
for $row in $matrix ::
    for $val in $row ::
        $sum += $val
    ;;
;;
? $sum == 21 :: $passed += 1 :: else :: >> red "[FAIL] nested loops" ;; $failed += 1 ;;

get_pair ::
    => [42, 99]
;;
[$x, $y] -> get_pair
? $x == 42 :: $passed += 1 :: else :: >> red "[FAIL] func+destruct" ;; $failed += 1 ;;

$s -> "  Hello, World!  "
&trim $s
&lower $s
&replace $s "," ""
&replace $s "!" ""
? $s == "hello world" :: $passed += 1 :: else :: >> red "[FAIL] chained ops" ;; $failed += 1 ;;

$config -> #json '{"debug": true, "port": 8080}'
? $config["port"] == 8080 :: $passed += 1 :: else :: >> red "[FAIL] json config" ;; $failed += 1 ;;

## ════════════════════════════════════════
>> "\n=========================================="
>> bold "  RESULTS"
>> "=========================================="
$total -> $passed + $failed
>> green "  Passed: {$passed}"
? $failed > 0 ::
    >> red "  Failed: {$failed}"
:: else ::
    >> green "  Failed: 0"
;;
>> "  Total:  {$total}"
>> "=========================================="
? $failed == 0 ::
    >> green "  ALL TESTS PASSED"
:: else ::
    >> red "  SOME TESTS FAILED"
;;
>> "=========================================="
